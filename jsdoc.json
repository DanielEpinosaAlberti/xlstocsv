{
  "source": {
    "include": ["backend/src", "frontend/src"],
    "includePattern": ".+\\.(js|jsx)$",
    "excludePattern": "(^|\\/|\\\\)_"
  },
  "opts": {
    "destination": "docs/generated",
    "recurse": true,
    "readme": "README.md"
  },
  "templates": {
    "default": {
      "includeDate": false
    }
  }
}
